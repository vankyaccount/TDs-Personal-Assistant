generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  password      String
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  tasks         Task[]
  emailDrafts   EmailDraft[]
  meetingNotes  MeetingNote[]
  btsImages     BTSImage[]
}

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("New Chat")
  persona   String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  quadrant    Int
  status      String   @default("pending")
  priority    String   @default("medium")
  dueDate     DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailDraft {
  id        String   @id @default(cuid())
  subject   String
  body      String
  template  String
  tone      Int      @default(50)
  context   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MeetingNote {
  id              String   @id @default(cuid())
  title           String
  transcript      String?
  structuredNotes Json?
  audioUrl        String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BTSImage {
  id        String   @id @default(cuid())
  prompt    String
  imageData String?
  context   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
